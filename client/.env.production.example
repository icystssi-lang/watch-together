# Used at build time (set as Railway Variables on the static client service, or copy to .env.production).
# Must be the public HTTPS origin of your Node/API service (no trailing slash).
VITE_SOCKET_URL=https://your-api-service.up.railway.app

# Recommended for production screen share reliability:
# include TURN in addition to STUN, otherwise some users only see black screen.
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"turn-user","credential":"turn-password"}]

# Optional - same as client/.env.development
# VITE_APP_COPYRIGHT_HOLDER=
# VITE_APP_BUILT_BY=
