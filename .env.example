# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d
DATABASE_PATH=./server/data/app.db

# First admin (created only when no admin exists in DB)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Optional
LOG_LEVEL=info
NODE_ENV=development

# Client (Vite) — copy to client/.env.development
# VITE_SOCKET_URL=http://localhost:3001
# Optional WebRTC ICE servers JSON (TURN recommended if screen share fails to connect)
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# Optional footer attribution (or edit client/src/siteMeta.ts)
# VITE_APP_COPYRIGHT_HOLDER=Your Company
# VITE_APP_BUILT_BY=Your Name
